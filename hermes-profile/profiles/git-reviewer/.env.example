# Git Reviewer Profile — Environment Template
# Copy to .env and fill in values

# REQUIRED: Discord bot token (get from https://discord.com/developers/applications)
# NOTE: Each profile/bot needs its OWN token — Discord disconnects duplicate connections
DISCORD_BOT_TOKEN=***REDACTED***

# GitHub credentials forwarded from host (from ~/.hermes/.env GITHUB_TOKEN)
# Do NOT set here — inherited from parent .env via docker_forward_env