# Database
DATABASE_URL=sqlite+aiosqlite:///./stocktoolkit.db

# JWT secret (generate with: openssl rand -hex 64)
SECRET_KEY=<generate with: openssl rand -hex 64>

# Encryption key for Fernet symmetric encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=<generate with: openssl rand -hex 32>

# Admin bootstrap
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<set via environment variable>
IS_DOCKER=false

# Log level
LOG_LEVEL=INFO
